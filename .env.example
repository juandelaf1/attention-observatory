# YouTube Data API v3
YOUTUBE_API_KEY='your_key_here'
YOUTUBE_QUERIES="digital creator,artificial intelligence,machine learning,data science,technology news,programming,startup,science"
YOUTUBE_MAX_CHANNELS=5
YOUTUBE_MAX_VIDEOS=25

# GitHub (fine-grained token)
GITHUB_TOKEN='your_token_here'

