# Variables de entorno para Attention Observatory
# Copia este archivo como .env y completa tus claves

# YouTube Data API v3
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un proyecto o selecciona uno existente
# 3. Activa YouTube Data API v3 (Biblioteca > YouTube Data API v3 > Habilitar)
# 4. Ve a Credenciales > Crear credenciales > API Key
# 5. (Recomendado) Restringe la key a YouTube Data API v3 solo
YOUTUBE_API_KEY=""

# Consulta de búsqueda para canales de YouTube (opcional, default: "digital creator")
# YOUTUBE_SEARCH_QUERY="data science"
# YOUTUBE_MAX_CHANNELS=5
# YOUTUBE_MAX_VIDEOS=20

# Reddit API (OAuth2 - Client Credentials)
# 1. Ve a https://www.reddit.com/prefs/apps
# 2. Haz scroll abajo y crea una nueva aplicación (script)
# 3. Copia el ID (justo debajo de "personal use script") como REDDIT_CLIENT_ID
# 4. Copia el secret como REDDIT_CLIENT_SECRET
# 5. User-Agent: cualquier string descriptivo, ej: "attention-observatory/0.1"
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USER_AGENT="attention-observatory/0.1"

# Subreddits a scrapear (opcional, separados por coma)
# REDDIT_SUBREDDITS="MachineLearning,datascience,artificial"
# REDDIT_POSTS_PER_SUB=50

# GitHub API Token (pat clásico con scope public_repo, o fine-grained sin repos)
# Crea uno en https://github.com/settings/tokens
# GITHUB_TOKEN="ghp_..."
